# VisaBud Environment Variables
# Copy this file to .env.local and fill in your values

# ===== SUPABASE (Database & Auth) =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc... (anon/public key from Supabase Settings)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc... (service role key from Supabase Settings)

# ===== STRIPE (Payments) =====
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_... (or pk_test_... for development)
STRIPE_SECRET_KEY=sk_live_... (or sk_test_... for development)
STRIPE_WEBHOOK_SECRET=whsec_... (from Stripe Webhook Settings)

# Stripe Price IDs (from Stripe Dashboard → Products → Price IDs)
STRIPE_PRICE_STANDARD=price_... (Standard tier price ID)
STRIPE_PRICE_PREMIUM=price_... (Premium tier price ID)
STRIPE_PRICE_EXPERT=price_... (Expert tier price ID)

# Optional: separate webhook secret for price sync endpoint
# STRIPE_PRICE_WEBHOOK_SECRET=whsec_... (if using a separate webhook for price events)

# ===== AI VISION PROVIDER =====
# Which AI provider to use for document validation: "claude" (default) or "openai"
VISION_PROVIDER=claude

# Anthropic (required if VISION_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-... (from console.anthropic.com)

# OpenAI (required if VISION_PROVIDER=openai, also used for other features)
OPENAI_API_KEY=sk-... (from platform.openai.com)

# Optional: override Claude model for premium reviews (default: claude-sonnet-4-20250514)
# CLAUDE_PREMIUM_MODEL=claude-opus-4-20250514

# ===== EMAIL (Resend) =====
RESEND_API_KEY=re_... (from resend.com dashboard)

# ===== ANALYTICS (Google Analytics 4) =====
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX (from Google Analytics)

# ===== APPLICATION =====
NEXT_PUBLIC_SITE_URL=https://visabud.co.uk (production URL)
NEXT_PUBLIC_APP_URL=https://visabud.co.uk (for auth callbacks)
NODE_ENV=production

# ===== NOTES =====
# - For local development, use pk_test_* and sk_test_* Stripe keys
# - For production, use pk_live_* and sk_live_* Stripe keys (LIVE MONEY!)
# - Supabase keys are found at: Project Settings → API
# - Stripe webhook secret is found at: Developers → Webhooks → Signing secret
# - Never commit .env.local to git; use .env.example only
