# Email Service Configuration
# Choose ONE provider: Resend (recommended) or SendGrid

# Option 1: Resend (recommended - simpler API)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=VisaBud <hello@visabud.co.uk>

# Option 2: SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
SENDGRID_LIST_ID=              # Optional: marketing list ID
EMAIL_FROM_ADDRESS=hello@visabud.co.uk

# Cron job security
CRON_SECRET=your-random-secret-here

# App URL (for email links)
NEXT_PUBLIC_APP_URL=https://visabud.co.uk
